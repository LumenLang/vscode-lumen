{
  "name": "lumenlang",
  "displayName": "Lumen Language",
  "description": "Language support for Lumen (.luma).",
  "version": "0.1.3",
  "icon": "icons/lumen.png",
  "publisher": "lumenlang",
  "license": "GPL-3.0",
  "engines": {
    "vscode": "^1.82.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "lumen",
    "luma",
    "language",
    "lsp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/LumenLang/vscode-lumen"
  },
  "activationEvents": [
    "onLanguage:lumen",
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "lumen.validateScript",
        "title": "Validate Lumen Script",
        "icon": "$(beaker)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "lumen.validateScript",
          "group": "navigation",
          "when": "resourceLangId == lumen"
        }
      ]
    },
    "languages": [
      {
        "id": "lumen",
        "aliases": [
          "Lumen"
        ],
        "extensions": [
          ".luma"
        ],
        "icon": {
          "light": "./icons/lumen.png",
          "dark": "./icons/lumen.png"
        }
      }
    ],
    "configuration": {
      "title": "Lumen",
      "properties": {
        "lumen.validation.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable validation via Lumen Headless (100% accurate diagnostics, identical plugin pipeline to a real server, without needing a Minecraft server running)."
        },
        "lumen.validation.trigger": {
          "type": "string",
          "default": "schedule",
          "enum": ["schedule", "save"],
          "enumDescriptions": [
            "Validate automatically on a fixed interval (skips if content hasn't changed since last check).",
            "Only validate when the file is saved."
          ],
          "description": "When to run Lumen Headless validation."
        },
        "lumen.validation.frequency": {
          "type": "integer",
          "default": 2000,
          "minimum": 500,
          "maximum": 30000,
          "description": "How often (in milliseconds) to re-validate on a schedule. Only applies when trigger is 'schedule'."
        },
        "lumen.lsp.diagnostics": {
          "type": "boolean",
          "default": false,
          "description": "Allow the Lumen LSP to show its own diagnostics alongside Headless validation. Note: LSP diagnostics are less accurate than Headless, but they are faster when typing constantly."
        }
      }
    }
  },
  "scripts": {
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "dependencies": {
    "vscode-languageclient": "^9.0.1"
  },
  "devDependencies": {
    "@vscode/vsce": "^2.22.0"
  }
}
